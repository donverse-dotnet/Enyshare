<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net9.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>

        <PackageId>Pocco.Svc.Organizations.InfoService.Grpc.Clients</PackageId>
        <VersionPrefix>0.0.1</VersionPrefix>
        <Authors>ggg-alpha</Authors>
        <Company>Donverse.net</Company>
        <PackageDescription>Poccoの組織の情報サービスのgRPCクライアントパッケージ。</PackageDescription>
        <PackageLicenseFile>LICENSE.md</PackageLicenseFile>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <RepositoryUrl>https://github.com/ggg-alpha/Pocco.Svc.Organizations</RepositoryUrl>
    </PropertyGroup>

    <PropertyGroup>
        <VersionSuffix>build-$([System.DateTimeOffset]::UtcNow.ToUnixTimeSeconds())</VersionSuffix>
        <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    </PropertyGroup>

    <ItemGroup>
        <None Include="../../../LICENSE.md" Pack="true" PackagePath="/" />
        <None Include="README.md" Pack="true" PackagePath="/" />
    </ItemGroup>

    <ItemGroup>
        <Protobuf Include="../../servers/InfoService/Protos/V0/Types/InfoChangesReply.proto" GrpcRoot="../../servers/InfoService/Protos" GrpcServices="None" />
        <Protobuf Include="../../servers/InfoService/Protos/V0/Types/CreateInfoData.proto" GrpcRoot="../../servers/InfoService/Protos" GrpcServices="None" />
        <Protobuf Include="../../servers/InfoService/Protos/V0/Types/DeleteInfoData.proto" GrpcRoot="../../servers/InfoService/Protos" GrpcServices="None" />
        <Protobuf Include="../../servers/InfoService/Protos/V0/Types/InfoModel.proto" GrpcRoot="../../servers/InfoService/Protos" GrpcServices="None" />
        <Protobuf Include="../../servers/InfoService/Protos/V0/Types/OrganizationData.proto" GrpcRoot="../../servers/InfoService/Protos" GrpcServices="None" />
        <Protobuf Include="../../servers/InfoService/Protos/V0/Services/InfoService.proto" GrpcRoot="../../servers/InfoService/Protos" GrpcServices="Client" />
        <Protobuf Include="../../servers/InfoService/Protos/V0/Types/UpdateInfoData.proto" GrpcRoot="../../servers/InfoService/Protos" GrpcServices="None" />
        <Protobuf Include="../../servers/InfoService/Protos/V0/Types/GetInfoData.proto" GrpcRoot="../../servers/InfoService/Protos" GrpcServices="None" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Grpc.Reflection" Version="2.71.0" PrivateAssets="all" />
        <PackageReference Include="Grpc.Net.Client" Version="2.71.0" PrivateAssets="all" />
        <PackageReference Include="Grpc.Tools" Version="2.72.0" PrivateAssets="all">
            <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
            <PrivateAssets>all</PrivateAssets>
        </PackageReference>
    </ItemGroup>

</Project>