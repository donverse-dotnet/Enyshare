<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <Protobuf Include="Protos/V0/Types/ChatCreateDataReply.proto" ProtoRoot="Protos/" GrpcServices="None" />
    <Protobuf Include="Protos/V0/Types/ChatCreateDataRequest.proto" ProtoRoot="Protos/" GrpcServices="None" />
    <Protobuf Include="Protos/V0/Types/ChatDeleteDataReply.proto" ProtoRoot="Protos/" GrpcServices="None" />
    <Protobuf Include="Protos/V0/Types/ChatDeleteDataRequest.proto" ProtoRoot="Protos/" GrpcServices="None" />
    <Protobuf Include="Protos/V0/Types/ChatGetDataReply.proto" ProtoRoot="Protos/" GrpcServices="None" />
    <Protobuf Include="Protos/V0/Types/ChatGetDataRequest.proto" ProtoRoot="Protos/" GrpcServices="None" />
    <Protobuf Include="Protos/V0/Types/ChatsModel.proto" ProtoRoot="Protos/" GrpcServices="None" />
    <Protobuf Include="Protos/V0/Types/ChatUpdateDataRequest.proto" ProtoRoot="Protos/" GrpcServices="None" />

    <Protobuf Include="Protos/V0/Services/OrganizationChats.proto" ProtoRoot="Protos/" GrpcServices="Server" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Grpc.AspNetCore" Version="2.64.0" />
  </ItemGroup>

</Project>
