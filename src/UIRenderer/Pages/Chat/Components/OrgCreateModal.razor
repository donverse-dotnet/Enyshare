<div class="w-100 h-100 flex-column justify-content-center align-items-center position-absolute ps-1 pe-1" style="top: 0; left: 0; z-index: 800; display: @(_hideCreateModal == true ? "none" : "flex"); background-color: #96909070;" @onclick="async (e) => await Hide(e)">
  <div class="w-100 d-flex flex-column justify-content-start align-items-center rounded-3 shadow-lg" style="max-width: 400px; padding: 20px; z-index: 801; background: var(--color_teal);" @onclick:stopPropagation="true">

    <div class="d-flex flex-column align-items-center justify-content-start overflow-y-auto h-100 w-100">
      <h3>新しい組織の作成</h3>
      <p>新しい組織のアイコンとサーバー名を設定して、組織をちょっとカスタマイズしましょう。ここで設定した内容は組織内設定から変更できます。</p>

      <div class="pt-2" id="uploadForm" novalidate>

        <div class="field w-100">
          <div class="d-flex flex-row justify-content-center align-items-center" style="gap:12px;">
            <div class="preview d-flex flex-column justify-content-center align-items-center" id="imagePreview" aria-live="polite">
              <i class="bi bi-image" style="font-size:45px;"></i>
              <p style="font-size: 12px;">アップロード</p>
            </div>
            <div class="d-flex flex-column w-100">
              <input id="image" name="image" type="file" accept="image/*" style="display:none;" />
              <div class="hint">対応形式: JPG, PNG, GIF 等。最大 5MB。</div>
              <div class="hint">まだダミー。ごめん (&gt; _ &lt;)</div>
              <div class="error" id="imageError" aria-hidden="true"></div>
            </div>
          </div>
        </div>
      </div>
      <div class="field w-100">
        <label for="name">名前（必須・30文字以内）</label>
        <input id="name" name="name" type="text" maxlength="30" required placeholder="例: 山田 太郎" @oninput="OnOrgNameChanged" />
        <div class="error">@_orgNameErrorMessage</div>
      </div>

      <div class="field w-100">
        <label for="description">簡単な説明（任意・200文字以内）</label>
        <textarea id="description" name="description" rows="4" maxlength="200" placeholder="この画像について短く説明してください（例: 京都の桜を撮影しました）" @oninput="OnOrgDescChanged"></textarea>
        <div class="error">@_orgDescErrorMessage</div>
      </div>

      <div style="display:flex;gap:8px;align-items:center">
        <button class="btn btn-primary" @onclick="async () => await SubmitCreateOrgAsync()">新規作成</button>
      </div>
    </div>
  </div>
</div>
