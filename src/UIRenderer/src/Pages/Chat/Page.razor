@page "/chat/"
@page "/chat/{OrgId?}"
@using Pocco.Client.Web.Pages.Chat.Components
@layout Empty

<div class="h-100 w-100 d-flex flex-column justify-content-start align-items-start overflow-hidden bg-light position-relative">
  <!-- Org select Modal -->
  <OrgSelectModal ParentPageRef="this" Logger="this.Logger" NavigationManager="this.NavigationManager" LocalStorageProvider="this.LocalStorageProvider" ApiClient="this.ApiClient" />

  <!-- Org join Modal -->
  <OrgJoinModal ParentPageRef="this" Logger="this.Logger" NavigationManager="this.NavigationManager" LocalStorageProvider="this.LocalStorageProvider" ApiClient="this.ApiClient" />

  <!-- Org create Modal -->
  <OrgCreateModal ParentPageRef="this" Logger="this.Logger" NavigationManager="this.NavigationManager" LocalStorageProvider="this.LocalStorageProvider" ApiClient="this.ApiClient" />

  <!-- Org settings Modal -->
  <OrgSettingsModal ParentPage="this" />

  <header class="w-100 d-flex flex-row justify-content-between align-items-center" style="height: 45px; background-color: var(--bs-orange);">
    <div class="h-100 d-flex flex-row justify-content-start align-items-center">
      <!-- Promotion -->
      <div class="h-100 d-flex flex-row justify-content-start align-items-center">
        <img src="@Assets["/assets/logos/pocco-icon.png"]" alt="Pocco is here!" style="width: 20px; height: 20px; margin-left: 10px;" />
        <h1 style="font-size: 16px; font-weight: bold; color: white; margin: 0 10px; padding: 0;">
          Pocco
        </h1>
      </div>
    </div>

    <!-- Switcher -->
    <div @onclick="async (e) => await OrgSelectModalRef!.Show(e)" class="d-flex flex-row justify-content-start align-items-center dropdown rounded-2 position-relative" style="width: 240px; margin: 0 25px; padding: 4px 8px; border: 1px solid gray; cursor: pointer;">
      <img src="https://placehold.jp/120x120.png" alt="Pocco is here!" class="rounded-2" style="width: 30px; height: 30px; margin-right: 5px;" />
      <div class="d-flex flex-grow-1" style="font-weight: 700;">
        Selected org name
      </div>
    </div>

    <!-- Account icon -->
    <div class="h-100 d-flex flex-row justify-content-end align-items-center" style="margin-right: 10px;">
      <img src="https://placehold.jp/120x120.png" alt="User icon" style="width: 30px; height: 30px; border-radius: 50%; cursor: pointer;" />
    </div>
  </header>

  <!-- Body -->
  <div class="h-100 w-100 d-flex flex-column justify-content-start align-items-start position-relative" style="background-color: var(--bs-cyan);">
    <!-- Sidebar -->
    <div class="h-100 d-flex flex-column justify-content-start align-items-center rounded-end-2 border-light" style="width: 250px; background-color: tomato; padding: 10px 4px;">
      <!-- Organization info center --> @* Mode: org/dm/welcome *@
      <OrgInfoCenter ParentPage="this" />

      <hr style="width: 95%;" />

      <!-- Channel list -->
      <ChatList ParentPage="this" />
    </div>
    <!-- Render are -->
  </div>
</div>
