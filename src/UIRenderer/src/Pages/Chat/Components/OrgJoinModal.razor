<div class="w-100 h-100 flex-column justify-content-center align-items-center position-absolute ps-1 pe-1"
  style="top: 0; left: 0; z-index: 700; display: @(_hideJoinModal == true ? "none" : "flex"); background-color: #96909070;"
  @onclick="async (e) => await Hide(e)">
  <div class="w-100 d-flex flex-column justify-content-start align-items-center bg-white rounded-3 shadow-lg"
    style="max-width: 400px; padding: 20px; z-index: 701;" @onclick:stopPropagation="true">

    <div class="d-flex flex-column align-items-center justify-content-start overflow-y-auto h-100 w-100">
      <h3>組織への参加</h3>
      <div class="field">
        <label for="name">招待コード</label>
        <input id="name" name="name" type="text" maxlength="30" required placeholder="Ex: abcdefg12345"
          @oninput="OnJoinCodeInputChange" />
        <div class="error">@_codeInputError</div>
      </div>
      <div style="display:flex;gap:8px;align-items:center">
        <button class="btn btn-primary" @onclick="async () => await OnJoinSubmitClicked()">参加する</button>
      </div>
    </div>
  </div>
</div>
