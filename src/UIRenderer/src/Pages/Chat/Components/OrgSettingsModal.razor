<div class="w-100 h-100 flex-column justify-content-center align-items-center position-absolute ps-1 pe-1" style="top: 0; left: 0; z-index: 500; display: @(_hideModal == true ? "none" : "flex"); background-color: #96909070;" @onclick="async (e) => await Hide(e)">
  <div class="w-100 d-flex flex-row justify-content-center align-items-start bg-white rounded-3 position-relative" style="max-width: 80%; height: 800px; z-index: 501;" @onclick:stopPropagation="true">

    <button class="btn btn-light position-absolute top-0 end-0 m-2" style="z-index: 502;" title="Close" @onclick="async (e) => await Hide(e)">
      <i class="bi bi-x-lg"></i>
    </button>

    <div class="h-100 d-flex flex-column" style="width: 250px; border-right: 1px solid #ccc;">
      <h4 style="height: 45px; border-bottom: 1px solid #ccc;">Settings</h4>
      <div class="d-flex flex-row align-items-center" style="height: 30px; border-bottom: 1px solid #ccc; margin-bottom: 10px; cursor: pointer;" @onclick="async () => await ChangeMode(OrgSettingsMode.General)">
        <h5>General</h5>
      </div>
    </div>
    <div class="h-100 flex-grow-1 d-flex flex-column">
      @if (_orgSettingsMode is OrgSettingsMode.General)
      {
        <div class="p-3 d-flex flex-column" style="min-height: 0; overflow-y: auto;">
          <h4>General Settings</h4>
          <p>Here you can configure general settings for your organization.</p>

          <div class="mt-4 p-3 bg-light d-flex flex-row align-items-center justify-content-between" style="border: 1px solid red; border-radius: 5px;">
            <div class="text-danger" style="font-weight: bold;">
              Confirm to delete this organization.
            </div>
            <button class="btn btn-danger" @onclick="async (e) => await OnDeleteOrganizationBtnClicked(e)">Delete organization</button>
          </div>
        </div>
      }
      else
      {
        <p>Unknown</p>
      }
    </div>
  </div>
</div>
