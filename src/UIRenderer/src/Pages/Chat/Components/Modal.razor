@page "/slide-sample"


<div class="switcher"
    style="display: @(IsShown ? "flex" : "none"); position: absolute; width: 100vw; height: 100vh; overflow: hidden; top: 0; left: 0; flex-direction: column; align-items: center; justify-content: center; background-color: #f0f0f060; border: 1px solid #ccc; border-radius: 8px; box-shadow: 2px 2px 12px rgba(0,0,0,0.1); z-index: 1000;">

    <div
        style="width: 300px; padding: 20px; background-color: white; border: 1px solid #ddd; border-radius: 8px; box-shadow: 1px 1px 8px rgba(0,0,0,0.05);">
        <div>
            <button @onclick="() => Switch(View.Page1)">Page1</button>
            <button @onclick="() => Switch(View.Page2)">Page2</button>
            <button @onclick="() => Switch(View.Page3)">Page3</button>
            <button @onclick="async () => await OnCloseClicked()">Close</button>
        </div>

        <div class="panels" style="position: relative; width: 100%; height: 150px; overflow: hidden; margin-top: 10px;">
            @if (previousType != null)
            {
                <div class="panel prev @prevCss">
                    <DynamicComponent Type="previousType" Parameters="previousParams" />
                </div>
            }

            <div class="panel curr @currCss">
                <DynamicComponent Type="currentType" Parameters="currentParams" />
            </div>
        </div>
    </div>
</div>
