<div class="w-100 h-100 flex-column justify-content-center align-items-center position-absolute ps-1 pe-1" style="top: 0; left: 0; z-index: 500; display: @(_hideModal == true ? "none" : "flex"); background-color: #96909070;" @onclick="async (e) => await Hide(e)">
  <div class="w-100 d-flex flex-column justify-content-center align-items-center bg-white rounded-3 shadow-lg" style="max-width: 80%; height: 800px; padding: 20px; z-index: 501;" @onclick:stopPropagation="true">
    <div class="w-100 d-flex flex-row justify-content-center align-items-center mb-3">
      <div class="h-100 d-flex flex-row justify-content-center align-items-center gap-2">
        <input type="text" class="search_org_input" placeholder="Search organizations..." style="width: 300px;" @oninput="OnOrgSearchInputChanged" />
        <button class="open_join_to_org_btn d-flex flex-row justify-content-center align-items-center border-0" style="cursor: pointer; border-radius: 5px;" @onclick="async (e) => await OnOrgJoinClicked(e)">
          <i class="bi bi-arrow-right" style="font-weight: bold; font-size: 25px;"></i>
        </button>
        <button class="open_create_org_btn d-flex flex-row justify-content-center align-items-center border-0" style="cursor: pointer; border-radius: 5px;" @onclick="async (e) => await OnOrgCreateClicked(e)">
          <i class="bi bi-plus-lg" style="font-weight: bold; font-size: 25px;"></i>
        </button>
      </div>
    </div>
    <div class="w-100 d-flex flex-column justify-content-start align-items-start flex-grow-1 overflow-scroll" style="min-height: 200px;">
      @foreach (var org in Orgs)
      {
        <div class="organization_list_item w-100 p-2 mb-2 rounded-2 d-flex flex-row justify-content-start align-items-center hover_effect" style="cursor: pointer; background-color: var(--bs-gray-200);" @onclick="@(async (e) => await OnOrgSwitcherOrgSelectedClicked(e, org.Id))">
          <img src="https://placehold.jp/120x120.png" alt="Organization icon" class="rounded-2" style="width: 40px; height: 40px; margin-right: 10px;" />
          <div>
            <h5 style="margin: 0; padding: 0;">@org.Name</h5>
            <p style="margin: 0; padding: 0;">@org.Description</p>
          </div>
        </div>
      }
    </div>
  </div>
</div>
